<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <appSettings>
        <!-- Đường dẫn tương đối đến thư mục VieNeu-TTS engine -->
        <add key="VieNeuTtsPath" value="VieNeu-TTS" />
        <!-- Tên file Python bridge script -->
        <add key="VieNeuBridgeScript" value="vieneu_bridge.py" />
        <!-- Tần số lấy mẫu đầu ra mặc định (Hz) -->
        <add key="DefaultSampleRate" value="48000" />
        <!-- Theme mặc định khi khởi động (0-5) -->
        <add key="DefaultThemeIndex" value="0" />
        <!-- Ngôn ngữ giao diện mặc định (vi / en) -->
        <add key="DefaultLanguage" value="vi" />
        <!-- Số mục lịch sử đọc tối đa lưu trữ -->
        <add key="MaxHistoryRecords" value="100" />
    </appSettings>
</configuration>