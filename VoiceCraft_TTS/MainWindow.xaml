<Window x:Class="VoiceCraft_TTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoiceCraft_TTS"
        mc:Ignorable="d"
        Title="VoiceCraft TTS Studio - Dual Engine (Windows Native &amp; AI Neural)"
        Height="780" Width="1200"
        MinHeight="650" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Foreground="#F8FAFC">

    <Window.Resources>
        <!-- Glassmorphism Card Style -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2563EB" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Header Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Area -->
            <RowDefinition Height="*"/>
            <!-- Footer Status Bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER BAR -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Margin="0,0,0,16" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="#3B82F6" Margin="0,0,12,0">
                        <TextBlock Text="🎙️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="VoiceCraft TTS Studio" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock Text="Hệ thống tổng hợp giọng nói Dual-Engine (.NET C# &amp; AI Neural)" FontSize="12" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status Badge -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="StatusBadge" Background="#065F46" CornerRadius="12" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtStatus" Text="AI Engine: Đã kết nối" FontSize="12" FontWeight="SemiBold" Foreground="#ECFDF5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Sidebar: Controls & Voice Selection -->
                <ColumnDefinition Width="340"/>
                <!-- Center: Text Editor & Audio Player Controls -->
                <ColumnDefinition Width="*"/>
                <!-- Right Sidebar: History & Quick Actions -->
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                <StackPanel>
                    <!-- Engine Selection Card -->
                    <Border Style="{StaticResource GlassCard}" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="⚙️ Nền Tảng Engine" FontSize="15" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,12"/>
                            
                            <RadioButton x:Name="RbWindowsEngine" Content="Windows Engine (Offline, 0-Latency)" 
                                         IsChecked="True" Foreground="#F8FAFC" FontSize="13" Margin="0,0,0,8"
                                         Checked="Engine_SelectionChanged"/>
                            <RadioButton x:Name="RbAiEngine" Content="AI Neural Engine (Giọng Đọc Tự Nhiên)" 
                                         Foreground="#F8FAFC" FontSize="13" Margin="0,0,0,4"
                                         Checked="Engine_SelectionChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- Voice Selection Card -->
                    <Border Style="{StaticResource GlassCard}" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="🗣️ Chọn Giọng Đọc" FontSize="15" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,12"/>
                            
                            <ComboBox x:Name="CboVoices" Height="36" FontSize="13" 
                                      Background="#0F172A" Foreground="#F8FAFC"
                                      Margin="0,0,0,10" SelectionChanged="CboVoices_SelectionChanged"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Ngôn ngữ: " FontSize="12" Foreground="#94A3B8"/>
                                <TextBlock x:Name="TxtVoiceLang" Text="Việt Nam / English" FontSize="12" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Parameters Card -->
                    <Border Style="{StaticResource GlassCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="🎛️ Tùy Chỉnh Âm Thanh" FontSize="15" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,14"/>

                            <!-- Speed Slider -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Tốc độ (Speed)" FontSize="13" Foreground="#CBD5E1"/>
                                <TextBlock Grid.Column="1" x:Name="TxtSpeedVal" Text="1.0x" FontSize="13" FontWeight="Bold" Foreground="#38BDF8"/>
                            </Grid>
                            <Slider x:Name="SliderSpeed" Minimum="-10" Maximum="10" Value="0" TickFrequency="1" 
                                    Margin="0,0,0,16" ValueChanged="SliderSpeed_ValueChanged"/>

                            <!-- Pitch Slider -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cao độ (Pitch)" FontSize="13" Foreground="#CBD5E1"/>
                                <TextBlock Grid.Column="1" x:Name="TxtPitchVal" Text="0" FontSize="13" FontWeight="Bold" Foreground="#38BDF8"/>
                            </Grid>
                            <Slider x:Name="SliderPitch" Minimum="-10" Maximum="10" Value="0" TickFrequency="1" 
                                    Margin="0,0,0,16" ValueChanged="SliderPitch_ValueChanged"/>

                            <!-- Volume Slider -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Âm lượng (Volume)" FontSize="13" Foreground="#CBD5E1"/>
                                <TextBlock Grid.Column="1" x:Name="TxtVolumeVal" Text="100%" FontSize="13" FontWeight="Bold" Foreground="#38BDF8"/>
                            </Grid>
                            <Slider x:Name="SliderVolume" Minimum="0" Maximum="100" Value="100" TickFrequency="5" 
                                    ValueChanged="SliderVolume_ValueChanged"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- CENTER MAIN PANEL -->
            <Grid Grid.Column="1" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <!-- Text Area -->
                    <RowDefinition Height="*"/>
                    <!-- Audio Wave Visualizer & Status -->
                    <RowDefinition Height="Auto"/>
                    <!-- Controls Bar -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Text Input Card -->
                <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header of Input Card -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📝 Văn Bản Cần Đọc" FontSize="15" FontWeight="Bold" Foreground="#38BDF8"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="📁 Tải file .txt" Style="{StaticResource SecondaryButton}" Click="BtnOpenFile_Click" Margin="0,0,8,0"/>
                                <Button Content="🗑️ Xóa hết" Style="{StaticResource SecondaryButton}" Click="BtnClear_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- TextBox Input -->
                        <TextBox Grid.Row="1" x:Name="TxtInputText" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Background="#0F172A" Foreground="#F8FAFC"
                                 BorderBrush="#334155" BorderThickness="1" FontSize="15" Padding="12"
                                 TextChanged="TxtInputText_TextChanged"/>

                        <!-- Footer Info of Input Card -->
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="TxtCharCount" Text="0 ký tự | 0 từ" FontSize="12" Foreground="#94A3B8"/>
                            <TextBlock Grid.Column="1" Text="Sẵn sàng" FontSize="12" Foreground="#64748B"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Audio Visualizer Animation Bar -->
                <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="16,10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="TxtPlaybackStatus" Text="⏹ Sẵn sàng đọc văn bản" 
                                   FontSize="13" FontWeight="SemiBold" Foreground="#CBD5E1" VerticalAlignment="Center"/>

                        <!-- Wave Visualizer Bar -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle x:Name="Bar1" Width="4" Height="12" Fill="#3B82F6" Margin="2" RadiusX="2" RadiusY="2"/>
                            <Rectangle x:Name="Bar2" Width="4" Height="20" Fill="#6366F1" Margin="2" RadiusX="2" RadiusY="2"/>
                            <Rectangle x:Name="Bar3" Width="4" Height="28" Fill="#8B5CF6" Margin="2" RadiusX="2" RadiusY="2"/>
                            <Rectangle x:Name="Bar4" Width="4" Height="16" Fill="#EC4899" Margin="2" RadiusX="2" RadiusY="2"/>
                            <Rectangle x:Name="Bar5" Width="4" Height="24" Fill="#3B82F6" Margin="2" RadiusX="2" RadiusY="2"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" x:Name="TxtTime" Text="00:00" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Controls Bar Card -->
                <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Play / Pause / Stop Buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BtnPlay" Content="▶  ĐỌC VĂN BẢN" Style="{StaticResource PrimaryButton}" Click="BtnPlay_Click" Margin="0,0,10,0"/>
                            <Button x:Name="BtnPause" Content="⏸  Tạm Dừng" Style="{StaticResource SecondaryButton}" Click="BtnPause_Click" Margin="0,0,10,0"/>
                            <Button x:Name="BtnStop" Content="⏹  Dừng" Style="{StaticResource SecondaryButton}" Click="BtnStop_Click"/>
                        </StackPanel>

                        <!-- Export Audio File Button -->
                        <Button Grid.Column="1" x:Name="BtnExport" Content="💾 Xuất File Audio (.WAV / .MP3)" 
                                Style="{StaticResource SecondaryButton}" Click="BtnExport_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT SIDEBAR (HISTORY) -->
            <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📜 Lịch Sử Đọc" FontSize="15" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,12"/>

                    <!-- History ListView -->
                    <ListView Grid.Row="1" x:Name="LstHistory" Background="Transparent" BorderThickness="0" 
                              Foreground="#F8FAFC" SelectionChanged="LstHistory_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0F172A" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" FontSize="13" FontWeight="SemiBold" 
                                                   TextTrimming="CharacterEllipsis" MaxHeight="38" Foreground="#F1F5F9"/>
                                        <Grid Margin="0,6,0,0">
                                            <TextBlock Text="{Binding Engine}" FontSize="11" Foreground="#38BDF8"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" 
                                                       FontSize="11" Foreground="#64748B" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Row="2" Content="🗑️ Xóa lịch sử" Style="{StaticResource SecondaryButton}" 
                            HorizontalAlignment="Stretch" Click="BtnClearHistory_Click" Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- FOOTER STATUS BAR -->
        <Border Grid.Row="2" Margin="0,12,0,0">
            <Grid>
                <TextBlock Text="✨ VoiceCraft TTS Studio - Phát triển trên nền tảng .NET 10 &amp; Python 3.12 AI Engine" 
                           FontSize="11" Foreground="#64748B" HorizontalAlignment="Left"/>
                <TextBlock Text="Sẵn sàng hoạt động" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
